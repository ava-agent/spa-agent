# Massage SPA Guide environment

DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>
JWT_SECRET=<your-session-signing-secret>
EXPO_PUBLIC_API_BASE_URL=
EXPO_PUBLIC_SITE_URL=https://spa.rxcloud.group

# Server-side Ark CodingPlan LLM configuration. Keep real values in local files
# or deployment secrets.
ARK_API_KEY=your_ark_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
ARK_CHAT_MODEL=doubao-seed-2-0-code-preview-260215

# Non-chat Manus Forge services: storage, data APIs, notifications, image
# generation, and transcription.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
